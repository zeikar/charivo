{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@charivo/core": ["packages/core/src/index.ts"],
      "@charivo/llm/openai": ["packages/llm/src/openai/index.ts"],
      "@charivo/llm/openclaw": ["packages/llm/src/openclaw/index.ts"],
      "@charivo/llm/remote": ["packages/llm/src/remote/index.ts"],
      "@charivo/llm/stub": ["packages/llm/src/stub/index.ts"],
      "@charivo/llm": ["packages/llm/src/index.ts"],
      "@charivo/server/openai": ["packages/server/src/openai/index.ts"],
      "@charivo/server/openclaw": ["packages/server/src/openclaw/index.ts"],
      "@charivo/realtime/openai": ["packages/realtime/src/openai/index.ts"],
      "@charivo/realtime/openai-agents": [
        "packages/realtime/src/openai-agents/index.ts"
      ],
      "@charivo/realtime/remote": ["packages/realtime/src/remote/index.ts"],
      "@charivo/realtime": ["packages/realtime/src/index.ts"],
      "@charivo/render": ["packages/render/src/index.ts"],
      "@charivo/render-live2d": ["packages/render-live2d/src/index.ts"],
      "@charivo/render/stub": ["packages/render/src/stub/index.ts"],
      "@charivo/stt": ["packages/stt/src/index.ts"],
      "@charivo/stt/openai": ["packages/stt/src/openai/index.ts"],
      "@charivo/stt/remote": ["packages/stt/src/remote/index.ts"],
      "@charivo/stt/web": ["packages/stt/src/web/index.ts"],
      "@charivo/tts": ["packages/tts/src/index.ts"],
      "@charivo/tts/openai": ["packages/tts/src/openai/index.ts"],
      "@charivo/tts/remote": ["packages/tts/src/remote/index.ts"],
      "@charivo/tts/web": ["packages/tts/src/web/index.ts"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "exclude": ["node_modules", "dist", ".turbo"]
}

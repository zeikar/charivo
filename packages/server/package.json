{
  "name": "@charivo/server",
  "version": "0.2.3",
  "description": "Server-side provider adapters for Charivo",
  "exports": {
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "import": "./dist/openai/index.mjs",
      "require": "./dist/openai/index.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw/index.d.ts",
      "import": "./dist/openclaw/index.mjs",
      "require": "./dist/openclaw/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@charivo/core": "workspace:*",
    "openai": "^4.47.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeikar/charivo.git",
    "directory": "packages/server"
  },
  "author": {
    "name": "Zeikar",
    "url": "https://github.com/zeikar"
  },
  "homepage": "https://github.com/zeikar/charivo#readme",
  "bugs": {
    "url": "https://github.com/zeikar/charivo/issues"
  }
}

{
  "version": 1,
  "name": "Test Face",
  "canvas": { "width": 1000, "height": 1000 },
  "parameters": [
    { "id": "ParamMouthOpenY", "name": "Mouth Open", "min": 0, "max": 1, "default": 0 },
    { "id": "ParamMouthForm", "name": "Mouth Form", "min": -1, "max": 1, "default": 0 },
    { "id": "ParamEyeLOpen", "name": "Eye L", "min": 0, "max": 1, "default": 1 },
    { "id": "ParamEyeROpen", "name": "Eye R", "min": 0, "max": 1, "default": 1 },
    { "id": "ParamEyeBallX", "name": "Gaze X", "min": -1, "max": 1, "default": 0 },
    { "id": "ParamEyeBallY", "name": "Gaze Y", "min": -1, "max": 1, "default": 0 },
    { "id": "ParamAngleX", "name": "Head Angle", "min": -30, "max": 30, "default": 0 },
    { "id": "ParamBreath", "name": "Breath", "min": 0, "max": 1, "default": 0 }
  ],
  "parts": [
    {
      "id": "head",
      "color": [0.98, 0.85, 0.74, 1],
      "width": 520,
      "height": 620,
      "order": 0,
      "transform": { "x": 0, "y": 0 },
      "bindings": [
        { "parameter": "ParamAngleX", "channel": "translateX", "from": -50, "to": 50 },
        { "parameter": "ParamBreath", "channel": "translateY", "from": 0, "to": -12 },
        { "parameter": "ParamAngleX", "channel": "rotate", "from": 6, "to": -6 }
      ]
    },
    {
      "id": "eyeL",
      "color": [0.16, 0.16, 0.2, 1],
      "width": 90,
      "height": 90,
      "order": 2,
      "transform": { "x": -110, "y": 70 },
      "bindings": [
        { "parameter": "ParamAngleX", "channel": "translateX", "from": -50, "to": 50 },
        { "parameter": "ParamBreath", "channel": "translateY", "from": 0, "to": -12 },
        { "parameter": "ParamEyeLOpen", "channel": "scaleY", "from": -0.85, "to": 0 },
        { "parameter": "ParamEyeBallX", "channel": "translateX", "from": -25, "to": 25 },
        { "parameter": "ParamEyeBallY", "channel": "translateY", "from": -20, "to": 20 }
      ]
    },
    {
      "id": "eyeR",
      "color": [0.16, 0.16, 0.2, 1],
      "width": 90,
      "height": 90,
      "order": 2,
      "transform": { "x": 110, "y": 70 },
      "bindings": [
        { "parameter": "ParamAngleX", "channel": "translateX", "from": -50, "to": 50 },
        { "parameter": "ParamBreath", "channel": "translateY", "from": 0, "to": -12 },
        { "parameter": "ParamEyeROpen", "channel": "scaleY", "from": -0.85, "to": 0 },
        { "parameter": "ParamEyeBallX", "channel": "translateX", "from": -25, "to": 25 },
        { "parameter": "ParamEyeBallY", "channel": "translateY", "from": -20, "to": 20 }
      ]
    },
    {
      "id": "mouth",
      "color": [0.78, 0.32, 0.36, 1],
      "width": 150,
      "height": 34,
      "order": 2,
      "transform": { "x": 0, "y": -150 },
      "bindings": [
        { "parameter": "ParamAngleX", "channel": "translateX", "from": -50, "to": 50 },
        { "parameter": "ParamBreath", "channel": "translateY", "from": 0, "to": -12 },
        { "parameter": "ParamMouthOpenY", "channel": "scaleY", "from": 0, "to": 3 },
        { "parameter": "ParamMouthForm", "channel": "scaleX", "from": -0.2, "to": 0.4 }
      ]
    }

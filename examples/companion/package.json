{
  "name": "companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "prebuild": "pnpm -w build",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "eval:memory": "vitest run --config testing/vitest.eval.config.ts",
    "eval:memory:check-sensitivity": "out=$(EVAL_INJECT_BREAK=1 vitest run --config testing/vitest.eval.config.ts -t 'extraction precision/recall meets threshold' 2>&1); code=$?; echo \"$out\"; if [ $code -ne 0 ] && echo \"$out\" | grep -q 'EXTRACTION_PRECISION_BELOW_THRESHOLD'; then exit 0; else exit 1; fi"
  },
  "dependencies": {
    "@charivo/core": "workspace:*",
    "@charivo/realtime": "workspace:*",
    "@charivo/realtime-avatar": "workspace:*",
    "@charivo/render": "workspace:*",
    "@charivo/render-live2d": "workspace:*",
    "@charivo/server": "workspace:*",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

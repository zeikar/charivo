{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@charivo/core": ["../../packages/core/src/index.ts"],
      "@charivo/realtime/remote": [
        "../../packages/realtime/src/remote/index.ts"
      ],
      "@charivo/realtime-avatar": [
        "../../packages/realtime-avatar/src/index.ts"
      ],
      "@charivo/realtime": ["../../packages/realtime/src/index.ts"],
      "@charivo/render": ["../../packages/render/src/index.ts"],
      "@charivo/render-live2d": ["../../packages/render-live2d"],
      "@charivo/server/openai": ["../../packages/server/src/openai/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "testing"]
}
